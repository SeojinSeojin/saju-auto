# Absolute path to the queue JSON file
ITEMS_JSON=/Users/yourname/saju/saju-posts/queue.json

# Absolute path to folder containing royalty-free audio tracks (.mp3 / .wav / .m4a)
AUDIO_DIR=/Users/yourname/saju/youtube-bot/audio

# Duration of each Short in seconds
SHORT_DURATION_SECS=7

# Upstash Redis REST endpoint (from Upstash console → REST API)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io

# Upstash Redis REST token (from Upstash console → REST API)
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# OAuth 2.0 client ID from Google Cloud Console
YOUTUBE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# OAuth 2.0 client secret from Google Cloud Console
YOUTUBE_CLIENT_SECRET=your_google_client_secret

# Path where the OAuth token file is saved after first-run auth
OAUTH_TOKEN_PATH=token.json

# Secret token that cron-job.org sends in X-Cron-Secret header
CRON_SECRET=replace_with_a_long_random_string

# Set to "true" to build the MP4 locally but skip the YouTube upload
DRY_RUN=false
